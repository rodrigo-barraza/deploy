{
  "name": "sun-deploy-kit",
  "version": "1.0.0",
  "private": true,
  "description": "Sun — Deploy Kit",
  "scripts": {
    "deploy": "bash deploy-all.sh",
    "deploy:dry": "bash deploy-all.sh --dry-run",
    "deploy:vault": "bash deploy-all.sh --only=vault-service",
    "deploy:apis": "bash deploy-all.sh --only=tools-service,portal-service,lights-service",
    "deploy:gateway": "bash deploy-all.sh --only=prism-service",
    "deploy:clients": "bash deploy-all.sh --only=retina-client,portal-client,rod-dev-client,lupos-bot",
    "deploy:prism-service": "bash ../prism-service/deploy.sh",
    "deploy:tools-service": "bash ../tools-service/deploy.sh",
    "deploy:portal-service": "bash ../portal-service/deploy.sh",
    "deploy:lights-service": "bash ../lights-service/deploy.sh",
    "deploy:lupos-bot": "bash ../lupos-bot/deploy.sh",
    "deploy:retina-client": "bash ../retina-client/deploy.sh",
    "deploy:portal-client": "bash ../portal-client/deploy.sh",
    "deploy:rod-dev-client": "bash ../rod-dev-client/deploy.sh",
    "deploy:clock-crew-service": "bash ../clock-crew-service/deploy.sh",
    "deploy:clock-crew-client": "bash ../clock-crew-client/deploy.sh",
    "deploy:messages-service": "bash ../messages-service/deploy.sh",
    "deploy:messages-client": "bash ../messages-client/deploy.sh"
  }
}
