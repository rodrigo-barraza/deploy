    "deploy:prism": "bash ../prism/deploy.sh",
    "deploy:tools-api": "bash ../tools-api/deploy.sh",
    "deploy:api": "bash ../api/deploy.sh",
    "deploy:lights": "bash ../lights/deploy.sh",
    "deploy:lupos": "bash ../lupos/deploy.sh",
    "deploy:retina": "bash ../retina/deploy.sh",
    "deploy:portal": "bash ../portal/deploy.sh",
    "deploy:rod-dev": "bash ../rod-dev/deploy.sh"
  }
}
