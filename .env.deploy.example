# ============================================================
# Sun Ecosystem — Deploy Bootstrap (Template)
# ============================================================
# Copy this file to .env.deploy and fill in the values.
# This is the single shared bootstrap for all deployed services.
# Injected into each container as .env via env_file.
# boot.js fetches remaining secrets from Vault at startup.
# ============================================================

VAULT_SERVICE_URL=
VAULT_SERVICE_TOKEN=

# ── Build-Time Overrides ────────────────────────────────────
# These are sourced by deploy.sh PRE_BUILD() hooks for services
# that need values baked into the build (e.g., NEXT_PUBLIC_*).
# Runtime-only values should be in Vault, not here.
# NEXT_PUBLIC_RODRIGO_SERVICE=http://<host>:6666
